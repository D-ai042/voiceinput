    },
    "portable": {
      "artifactName": "VoiceInput.exe"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^24.9.1"
  }
}

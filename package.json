{
  "name": "node-voice-input",
  "version": "1.0.0",
  "description": "VoiceInput - 语音输入小助手",
  "author": "VoiceInput",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
